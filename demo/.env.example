# Copy this file to `.env` in the same directory before running
# `docker compose up -d`. Values below are LOCAL-DEV-ONLY; do not reuse in
# any shared or production-adjacent environment.
#
# Why env-var instead of committing literals to docker-compose.yaml?
# Prior releases had the admin token inlined in 4 places. Copy-paste risk
# was material; a world-known token is a time-bomb. With this file the
# token lives in exactly one uncommitted location (.env) and every
# reference in the stack reads ${INFLUX_ADMIN_TOKEN} from there.

# InfluxDB
INFLUX_ORG=winlab
INFLUX_BUCKET=ves
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin-local-dev-CHANGE-ME
INFLUX_ADMIN_TOKEN=dev-token-local-only-CHANGE-ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-local-dev-CHANGE-ME
