  "description": "NR cell CU PM counters landing in the influxlogger bucket: RRC connection establishment and NG handover execution. Validated end-to-end on 2026-04-19 against nonrtric-plt-pmlog:1.1.0 via the minimal-probe stack. See docs/schema-ground-truth-reference-2026-04-19-influxlogger-source.md: measurement is the full DN (SubNetwork=...,ManagedElement=...,NRCellCU=...), no user tags, fields are the raw counter names. Datasource UID is hardcoded to 'influxdb-ves' to match provisioning.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "RRC Connection Establishment (attempts vs success) per cell",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"RRC.ConnEstabAtt.sum\") AS attempts, mean(\"RRC.ConnEstabSucc.sum\") AS success FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellCU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellCU=(\\d+)\\.(attempts|success)" },
            "properties": [{ "id": "displayName", "value": "$1 / NRCellCU=$2 ($3)" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } }
    },
    {
      "type": "stat",
      "title": "RRC Connection Success Rate (last value)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 2,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT (last(\"RRC.ConnEstabSucc.sum\") / last(\"RRC.ConnEstabAtt.sum\")) * 100 FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellCU=.*$/ WHERE $timeFilter GROUP BY *",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellCU=(\\d+)" },
            "properties": [{ "id": "displayName", "value": "$1 / cell $2" }]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "NG Handover Execution (attempts vs success) per cell",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 3,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"NG.HOExeAtt\") AS attempts, mean(\"NG.HOExeSucc\") AS success FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellCU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellCU=(\\d+)\\.(attempts|success)" },
            "properties": [{ "id": "displayName", "value": "$1 / NRCellCU=$2 ($3)" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } }
    },
    {
