      "title": "NG Handover Success Rate (last value)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 4,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT (last(\"NG.HOExeSucc\") / last(\"NG.HOExeAtt\")) * 100 FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellCU=.*$/ WHERE $timeFilter GROUP BY *",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
