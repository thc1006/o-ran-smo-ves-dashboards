  "panels": [
    {
      "type": "timeseries",
      "title": "PDCP Downlink Volume (DRB.PdcpSduVolumeDl_Filter)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"DRB.PdcpSduVolumeDl_Filter\") FROM /^SubNetwork=.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
