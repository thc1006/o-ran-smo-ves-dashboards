  "description": "Prototype dashboard for NR cell DU PM counters landing in the 'ves' bucket. Built against the 2026-04-19 demo-layer schema probe (NOT yet validated against real nonrtric-plt-influxlogger). See docs/schema-ground-truth-reference-2026-04-19-demo.md for the query contract.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "PDCP Downlink Volume (DRB.PdcpSduVolumeDl_Filter) per cell",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"DRB.PdcpSduVolumeDl_Filter\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellDU=(\\d+)" },
            "properties": [{ "id": "displayName", "value": "$1 / NRCellDU=$2" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } }
    },
    {
      "type": "timeseries",
      "title": "PRB Usage DL (RRU.PrbUsedDl) per cell",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 2,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"RRU.PrbUsedDl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellDU=(\\d+)" },
            "properties": [{ "id": "displayName", "value": "$1 / NRCellDU=$2" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } }
    },
    {
      "type": "stat",
      "title": "Active UEs per cell (last value)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 3,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT last(\"DRB.MeanActiveUeDl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellDU=(\\d+)" },
            "properties": [{ "id": "displayName", "value": "$1 / cell $2" }]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "PRB Usage UL (RRU.PrbUsedUl) per cell",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 4,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"RRU.PrbUsedUl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "SubNetwork=[^,]*,ManagedElement=([^,]+),NRCellDU=(\\d+)" },
            "properties": [{ "id": "displayName", "value": "$1 / NRCellDU=$2" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max"] } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "style": "dark",
  "tags": ["ves", "o-ran", "smo", "prototype"],
  "templating": {
    "list": [
      {
        "name": "subnetwork",
        "label": "SubNetwork",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
        "query": "SHOW MEASUREMENTS",
        "regex": "/^SubNetwork=([^,]+),/",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1,
        "multi": false
      },
      {
        "name": "gnb",
        "label": "gNB",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
        "query": "SHOW MEASUREMENTS",
        "regex": "/ManagedElement=([^,]+),/",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
