        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "type": "stat",
      "title": "Active UEs per cell (last value)",
