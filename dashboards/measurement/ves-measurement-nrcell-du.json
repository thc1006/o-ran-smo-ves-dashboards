          "query": "SELECT mean(\"RRU.PrbUsedDl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
