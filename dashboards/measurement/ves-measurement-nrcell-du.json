  "description": "NR cell DU PM counters landing in the influxlogger bucket. Validated end-to-end on 2026-04-19 against nonrtric-plt-pmlog:1.1.0 via the minimal-probe stack (Kafka -> pmlog -> InfluxDB). See docs/schema-ground-truth-reference-2026-04-19-influxlogger-source.md: measurement is the full DN (SubNetwork=...,ManagedElement=...,NRCellDU=...), no user tags, fields are GranularityPeriod plus the raw counter names. Datasource UID is hardcoded to 'influxdb-ves' to match provisioning; for grafana.com upload use, re-export via UI so JSON picks up __inputs / ${DS_INFLUXDB} templating (tracked for v0.2.0).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "PDCP Downlink Volume (DRB.PdcpSduVolumeDl_Filter) per cell",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-ves" },
          "query": "SELECT mean(\"DRB.PdcpSduVolumeDl_Filter\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "type": "timeseries",
      "title": "PRB Usage DL (RRU.PrbUsedDl) per cell",
