{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "NR cell DU PM counters landing in the influxlogger bucket. Validated end-to-end on 2026-04-19 against nonrtric-plt-pmlog:1.1.0 via the minimal-probe stack (Kafka -> pmlog -> InfluxDB). See docs/schema-ground-truth-reference-2026-04-19-influxlogger-source.md: measurement is the full DN (SubNetwork=...,ManagedElement=...,NRCellDU=...), no user tags, fields are GranularityPeriod plus the raw counter names.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "PDCP Downlink Volume (DRB.PdcpSduVolumeDl_Filter) per cell",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 9
      },
      "datasource": "${DS_INFLUXDB}",
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_INFLUXDB}",
          "query": "SELECT mean(\"DRB.PdcpSduVolumeDl_Filter\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "PRB Usage DL (RRU.PrbUsedDl) per cell",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 9
      },
      "datasource": "${DS_INFLUXDB}",
      "id": 2,
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_INFLUXDB}",
          "query": "SELECT mean(\"RRU.PrbUsedDl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "type": "stat",
      "title": "Active UEs per cell (last value)",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 7
      },
      "datasource": "${DS_INFLUXDB}",
      "id": 3,
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_INFLUXDB}",
          "query": "SELECT last(\"DRB.MeanActiveUeDl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY *",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "PRB Usage UL (RRU.PrbUsedUl) per cell",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 7
      },
      "datasource": "${DS_INFLUXDB}",
      "id": 4,
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_INFLUXDB}",
          "query": "SELECT mean(\"RRU.PrbUsedUl\") FROM /^SubNetwork=$subnetwork.*ManagedElement=$gnb.*NRCellDU=.*$/ WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "resultFormat": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": ".*ManagedElement=([^,]+),NRCellDU=(\\d+)\\..*",
            "renamePattern": "$1 / cell $2"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "style": "dark",
  "tags": [
    "ves",
    "o-ran",
    "smo",
    "influxlogger",
    "nrcell-du"
  ],
  "templating": {
    "list": [
      {
        "name": "subnetwork",
        "label": "SubNetwork",
        "type": "query",
        "datasource": "${DS_INFLUXDB}",
        "query": "SHOW MEASUREMENTS",
        "regex": "/^SubNetwork=([^,]+),/",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false
      },
      {
        "name": "gnb",
        "label": "gNB",
        "type": "query",
        "datasource": "${DS_INFLUXDB}",
        "query": "SHOW MEASUREMENTS",
        "regex": "/ManagedElement=([^,]+),/",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "VES NR cell DU measurement",
  "uid": "ves-nrcell-du",
  "version": 4,
  "weekStart": "",
